# Docker Compose MySQL
MYSQL_DATABASE=realtime_tile_game
MYSQL_USER=rtg_user
MYSQL_PASSWORD=replace-with-local-database-password
MYSQL_ROOT_PASSWORD=replace-with-local-root-password

# Host direct-run Backend
DB_URL=jdbc:mysql://localhost:33307/realtime_tile_game?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=rtg_user
DB_PASSWORD=replace-with-local-database-password
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
SERVER_PORT=8080

# Local browser origins only. Classroom LAN origins belong to Phase 5.5-C.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Generate a private Base64 value that decodes to at least 32 bytes.
# Never commit or distribute the generated value.
JWT_ACCESS_SECRET_BASE64=replace-with-generated-base64-secret
JWT_ISSUER=realtime-tile-game
JWT_AUDIENCE=realtime-tile-game-web
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_NAME=rtg_refresh

# Docker host port mappings
DOCKER_MYSQL_HOST_PORT=33307
DOCKER_BACKEND_HOST_PORT=8080
DOCKER_FRONTEND_HOST_PORT=5173
