MYSQL_DATABASE=realtime_tile_game
MYSQL_USER=rtg_user
MYSQL_PASSWORD=change
MYSQL_ROOT_PASSWORD=change

DB_URL=jdbc:mysql://localhost:3307/realtime_tile_game?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=rtg_user
DB_PASSWORD=change
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Generate a private Base64 value that decodes to at least 32 bytes.
JWT_ACCESS_SECRET_BASE64=replace-with-generated-base64-secret
JWT_ISSUER=realtime-tile-game
JWT_AUDIENCE=realtime-tile-game-web
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_NAME=rtg_refresh
